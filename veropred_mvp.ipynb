                <span>{value}%</span>
            </div>
            <div class="vp-progress-wrap">
                <div class="vp-progress-bar" style="width:{value}%;"></div>
            </div>
        </div>
        """

    completed = len(state.completed_missions)
    total = len(MISSIONS)

    return f"""
    <div class="vp-card">
        <h3>Painel de maturidade</h3>
