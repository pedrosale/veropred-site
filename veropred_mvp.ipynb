                        transforma texto em ação e cria clareza para decisão.
                    </div>
                    <ul class="vp-list">{how}</ul>
                </div>

                <div class="vp-card">
                    <h3>Estrutura esperada</h3>
                    <div class="vp-text">
                        Use o molde abaixo como referência. Não copie mecanicamente. Complete com raciocínio próprio.
                    </div>
                    <br>
                    <div class="vp-structure">{mission['expected_structure']}</div>
                </div>
            </div>

            <div>
                {render_attributes_panel()}
                <div class="vp-card">
                    <h3>Critério de avanço</h3>
                    <div class="vp-text">
                        Você avança apenas se demonstrar estrutura mínima, contexto, clareza e organização operacional.
                    </div>
                    <div class="vp-divider"></div>
                    <div class="vp-small">
                        Tentativas nesta missão: {state.attempts.get(mission['id'], 0)}
                    </div>
                </div>
            </div>
        </div>
    </div>
    """


def render_feedback(result: Dict, mission: Dict) -> str:
    css_class = "vp-feedback-success" if result["passed"] else "vp-feedback-fail"
    title = "Missão validada" if result["passed"] else "Ajuste necessário"

    strengths = "".join([f"<li>{s}</li>" for s in result["strengths"]])
    gaps = "".join([f"<li>{g}</li>" for g in result["gaps"]])

    checks = "".join([
        f"<li>{k}: {'OK' if v else 'Ajustar'}</li>"
        for k, v in result["checks"].items()
    ])

    metrics = result["metrics"]

    return f"""
    {STYLE}
    <div class="{css_class}">
        <div class="vp-feedback-title">{title}</div>
        <div class="vp-text">{result['diagnosis']}</div>

        <div class="vp-divider"></div>

        <h3 style="color:#d6a85f; margin-bottom:8px;">O que funcionou</h3>
        <ul class="vp-list">{strengths if strengths else "<li>Ainda não há elementos fortes o suficiente para destacar.</li>"}</ul>

        <h3 style="color:#d6a85f; margin:18px 0 8px;">O que precisa melhorar</h3>
        <ul class="vp-list">{gaps if gaps else "<li>Nenhum ajuste crítico identificado.</li>"}</ul>

        <h3 style="color:#d6a85f; margin:18px 0 8px;">Validação objetiva</h3>
        <ul class="vp-list">{checks}</ul>

        <div class="vp-divider"></div>

        <div class="vp-small">
            Caracteres: {metrics['chars']} · Linhas: {metrics['lines']} ·
            Seções detectadas: {metrics['section_hits']} ·
            Termos contextuais: {metrics['context_hits']} ·
            Marcadores estruturais: {metrics['structural_titles']}
        </div>
    </div>
    """


def render_completion() -> str:
    avg = int(sum(state.attributes.values()) / len(state.attributes))

    return render_header() + f"""
        <div class="vp-grid">
            <div>
                <div class="vp-card">
                    <h2>Jornada 01 concluída</h2>
                    <div class="vp-text">
                        Você concluiu o primeiro ciclo da jornada <b>Analista Perdido</b>.
                        A evolução demonstrada não foi pontuação superficial: foi capacidade de transformar
                        ambiguidade em estrutura operacional.
                        <br><br>
                        Maturidade média atual: <b>{avg}%</b>.
                    </div>
                </div>

                <div class="vp-card">
                    <h3>Competências ativadas</h3>
                    <div class="vp-text">
                        Clareza executiva, síntese operacional, estruturação de problemas,
                        uso mais maduro de IA externa, organização de hipóteses e tradução de caos em plano de ação.
                    </div>
                </div>
            </div>
            <div>
                {render_attributes_panel()}
            </div>
        </div>
    </div>
    """


# ============================================================
# 7. COMPONENTES INTERATIVOS
# ============================================================

main_output = widgets.Output()
feedback_output = widgets.Output()

answer_box = widgets.Textarea(
    value="",
    placeholder="Cole aqui sua estrutura operacional, prompt ou resposta executiva.",
    layout=widgets.Layout(width="100%", height="300px")
)

start_button = widgets.Button(
    description="Iniciar jornada",
    button_style="",
    layout=widgets.Layout(width="100%", height="52px")
)

submit_button = widgets.Button(
    description="Enviar resposta",
    button_style="",
    layout=widgets.Layout(width="100%", height="52px")
)

next_button = widgets.Button(
    description="Próxima missão",
    button_style="",
    layout=widgets.Layout(width="100%", height="52px")
)

restart_button = widgets.Button(
    description="Reiniciar",
    button_style="",
    layout=widgets.Layout(width="100%", height="52px")
)

button_row_intro = widgets.HBox(
    [start_button],
    layout=widgets.Layout(width="100%", gap="12px")
)

button_row_mission = widgets.HBox(
    [submit_button, next_button, restart_button],
    layout=widgets.Layout(width="100%", gap="12px")
)


def style_buttons():
    start_button.style.button_color = "#b87333"
    submit_button.style.button_color = "#d6a85f"
    next_button.style.button_color = "#8a552b"
    restart_button.style.button_color = "#242424"

    start_button.style.font_weight = "700"
    submit_button.style.font_weight = "700"
    next_button.style.font_weight = "700"
    restart_button.style.font_weight = "700"


style_buttons()


# ============================================================
# 8. FLUXO DO JOGO
# ============================================================

def current_mission() -> Dict:
    return MISSIONS[state.current_mission_index]


def show_intro():
    clear_output(wait=True)

    state.started = False
    next_button.disabled = True

    with main_output:
        clear_output(wait=True)
        display(HTML(render_intro()))

    display(main_output)
    display(button_row_intro)


def show_mission():
    clear_output(wait=True)

    mission = current_mission()
    state.started = True
    state.last_passed = False

    answer_box.value = ""
    answer_box.placeholder = mission["placeholder"]

    next_button.disabled = True
    submit_button.disabled = False

    with main_output:
        clear_output(wait=True)
        display(HTML(render_mission(mission)))

    with feedback_output:
        clear_output(wait=True)

    display(main_output)

    display(HTML("""
    <style>
    .vp-answer-title {
        color: #d6a85f;
        font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-size: 14px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin: 12px 0 10px 0;
    }
    </style>
    <div class="vp-answer-title">Sua resposta</div>
    """))

    display(answer_box)
    display(button_row_mission)
    display(feedback_output)


def show_completion():
    clear_output(wait=True)

    with main_output:
        clear_output(wait=True)
        display(HTML(render_completion()))

    display(main_output)
    display(restart_button)


def on_start_clicked(_):
    show_mission()


def on_submit_clicked(_):
    mission = current_mission()
    mission_id = mission["id"]

    state.attempts[mission_id] = state.attempts.get(mission_id, 0) + 1

    result = evaluate_response(answer_box.value, mission)
    state.last_passed = result["passed"]

    if result["passed"]:
        apply_mission_gain(mission)
        next_button.disabled = False
        submit_button.disabled = False
    else:
        next_button.disabled = True
        submit_button.disabled = False

    with feedback_output:
        clear_output(wait=True)
        display(HTML(render_feedback(result, mission)))

    with main_output:
        clear_output(wait=True)
        display(HTML(render_mission(mission)))


def on_next_clicked(_):
    if not state.last_passed:
        return

    if state.current_mission_index < len(MISSIONS) - 1:
        state.current_mission_index += 1
        show_mission()
    else:
        show_completion()


def on_restart_clicked(_):
    global state
    state = GameState()
    show_intro()


start_button.on_click(on_start_clicked)
submit_button.on_click(on_submit_clicked)
next_button.on_click(on_next_clicked)
restart_button.on_click(on_restart_clicked)


# ============================================================
# 9. INICIALIZAÇÃO
# ============================================================

show_intro()
