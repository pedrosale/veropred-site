@dataclass
class GameState:
    current_mission_index: int = 0
    started: bool = False
    completed_missions: List[int] = field(default_factory=list)
    attributes: Dict[str, int] = field(default_factory=lambda: {attr: 0 for attr in ATTRIBUTES})
    attempts: Dict[int, int] = field(default_factory=dict)
    last_feedback: str = ""
    last_passed: bool = False


state = GameState()


# ============================================================
# 4. UTILITÁRIOS
# ============================================================

def normalize_text(text: str) -> str:
    text = text.lower()
    replacements = {
        "á": "a", "à": "a", "ã": "a", "â": "a",
        "é": "e", "ê": "e",
        "í": "i",
        "ó": "o", "ô": "o", "õ": "o",
        "ú": "u",
        "ç": "c"
    }
    for old, new in replacements.items():
        text = text.replace(old, new)
    return text


def count_hits(text: str, terms: List[str]) -> Tuple[int, List[str]]:
    normalized = normalize_text(text)
    found = []
    for term in terms:
        term_norm = normalize_text(term)
        if term_norm in normalized:
            found.append(term)
    return len(set(found)), sorted(set(found))


def count_structural_titles(text: str) -> int:
    lines = [line.strip() for line in text.splitlines() if line.strip()]
    title_like = 0

    for line in lines:
        if ":" in line and len(line) <= 80:
            title_like += 1
        elif re.match(r"^\d+[\.\)]\s+", line):
            title_like += 1
        elif re.match(r"^[-•]\s+", line):
            title_like += 1

    return title_like


def detect_generic_answer(text: str) -> bool:
    clean = normalize_text(text)
    clean = re.sub(r"[^a-z0-9\s]", " ", clean)
    words = clean.split()
    unique_words = set(words)

    if len(words) < 45:
        return True

    if len(unique_words) < 25:
        return True

    keyword_only = {"resumo", "prioridade", "acao", "acoes", "prazo", "responsavel", "proximo", "passo"}
    if len(unique_words.intersection(keyword_only)) >= 4 and len(words) < 70:
        return True

    return False


# ============================================================
# 5. AVALIAÇÃO
# ============================================================

def evaluate_response(answer: str, mission: Dict) -> Dict:
    answer = answer.strip()
    lines = [line for line in answer.splitlines() if line.strip()]

    section_hits, found_sections = count_hits(answer, mission["required_sections"])
    context_hits, found_context = count_hits(answer, mission["required_context_terms"])
    structural_titles = count_structural_titles(answer)
    generic = detect_generic_answer(answer)

    checks = {
        "Tamanho mínimo": len(answer) >= mission["min_chars"],
        "Mínimo de linhas": len(lines) >= mission["min_lines"],
        "Seções estruturadas": section_hits >= mission["min_section_hits"],
        "Contexto do caso": context_hits >= mission["min_context_hits"],
        "Organização visível": structural_titles >= 5,
        "Não genérica": not generic
    }

    passed = all(checks.values())

    strengths = []
    gaps = []

    if checks["Tamanho mínimo"]:
        strengths.append("Você desenvolveu a resposta com densidade suficiente para análise operacional.")
    else:
        gaps.append(
            f"Sua resposta ainda está curta. Ela precisa ter pelo menos {mission['min_chars']} caracteres para demonstrar raciocínio, não apenas intenção."
        )

    if checks["Mínimo de linhas"]:
        strengths.append("A resposta já apresenta divisão visual adequada, o que facilita leitura executiva.")
    else:
        gaps.append(
            f"A resposta precisa de mais quebras e organização. Use pelo menos {mission['min_lines']} linhas com blocos claros."
        )

    if checks["Seções estruturadas"]:
        strengths.append("Você utilizou seções compatíveis com uma entrega operacional.")
    else:
        gaps.append(
            "Faltam seções operacionais claras. Uma boa resposta precisa separar blocos como resumo, prioridades, ações, responsáveis e próximos passos."
        )

    if checks["Contexto do caso"]:
        strengths.append("Você conectou a resposta ao contexto real da missão.")
    else:
        gaps.append(
            "A resposta ainda parece genérica. Ela precisa mencionar elementos do caso, como churn, clientes, reunião, diretoria, áreas envolvidas ou prazo."
        )

    if checks["Organização visível"]:
        strengths.append("A estrutura visual ajuda a transformar informação dispersa em execução.")
    else:
        gaps.append(
            "A organização ainda não está suficientemente visível. Use títulos, listas, numeração e blocos de decisão."
        )

    if checks["Não genérica"]:
        strengths.append("A resposta demonstra elaboração própria, não apenas palavras soltas.")
    else:
        gaps.append(
            "Sua resposta ainda está genérica. Escrever apenas palavras como resumo, prioridade, ação e prazo não demonstra competência operacional."
        )

    if passed:
        diagnosis = (
            f"Competência mínima demonstrada: {mission['competency']}. "
            "Você transformou ambiguidade em estrutura, o que é o núcleo da maturidade operacional com IA."
        )
    else:
        diagnosis = (
            "Ainda não há maturidade operacional mínima para avançar. "
            "Ajuste sua resposta para transformar informação em execução: contexto, estrutura, prioridade, ação e consequência."
        )

    return {
        "passed": passed,
        "checks": checks,
        "strengths": strengths,
        "gaps": gaps,
        "diagnosis": diagnosis,
        "found_sections": found_sections,
        "found_context": found_context,
        "metrics": {
            "chars": len(answer),
            "lines": len(lines),
            "section_hits": section_hits,
            "context_hits": context_hits,
            "structural_titles": structural_titles
        }
    }


def apply_mission_gain(mission: Dict):
    mission_id = mission["id"]

    if mission_id not in state.completed_missions:
        state.completed_missions.append(mission_id)

        for attr, gain in mission["attributes_gain"].items():
            state.attributes[attr] = min(100, state.attributes.get(attr, 0) + gain)


